# Production ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Development ports
BACKEND_DEV_PORT=8000
FRONTEND_DEV_PORT=5173

# Frontend API endpoints
FRONTEND_PROD_API_URL=/api
FRONTEND_DEV_API_URL=http://localhost:8000/api

# Backend CORS
ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Backend limits
MAX_FILE_SIZE_MB=50
MAX_CSV_ROWS=1000000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_PER_WINDOW=60
RATE_LIMIT_GENERATE_PER_WINDOW=20
RATE_LIMIT_ANONYMIZE_PER_WINDOW=30
RATE_LIMIT_DEANONYMIZE_PER_WINDOW=30
RATE_LIMIT_CSV_HEADERS_PER_WINDOW=30
RATE_LIMIT_VALIDATE_JSON_PER_WINDOW=30
